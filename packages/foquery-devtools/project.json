{
  "name": "foquery-devtools",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/foquery-devtools/src",
  "projectType": "application",
  "targets": {
    "build": {
      "command": "node scripts/build-devtools.mjs",
      "options": {
        "cwd": "packages/foquery-devtools"
      }
    },
    "test": {
      "command": "npx playwright test --config playwright.config.ts",
      "options": {
        "cwd": "packages/foquery-devtools"
      }
    },
    "lint": {
      "command": "eslint packages/foquery-devtools/src"
    }
  }
}
