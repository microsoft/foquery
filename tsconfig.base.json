{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2021", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "foquery": ["./packages/foquery/src/index.ts"],
      "foquery/devtools": ["./packages/foquery/src/devtools.ts"],
      "foquery/iframe": ["./packages/foquery/src/iframe.ts"],
      "foquery-react": ["./packages/foquery-react/src/index.ts"],
      "foquery-react/iframe": ["./packages/foquery-react/src/iframe.tsx"],
      "foquery-dom": ["./packages/foquery-dom/src/index.ts"],
      "foquery-dom/iframe": ["./packages/foquery-dom/src/iframe.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
